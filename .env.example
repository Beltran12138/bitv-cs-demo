NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required: DeepSeek Chat API
DEEPSEEK_API_KEY=sk-...

# Optional: enables full pgvector RAG (run POST /api/seed after adding)
OPENAI_API_KEY=sk-...

# Optional: protects the /api/seed endpoint
SEED_SECRET=your-secret

# Optional: Langfuse LLMOps — traces every DeepSeek call, scores user feedback
# Get keys at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
